rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔐 USERS
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      // user can update their own data BUT NOT role
      allow update: if request.auth.uid == userId
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // 📁 FILES
    match /files/{fileId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";

      // 💬 COMMENTS — any signed-in user can post
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null &&
          (
            request.auth.uid == resource.data.authorId ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
          );
      }

      // ❤️ LIKES
      match /likes/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 📂 CATEGORIES
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // 📢 ANNOUNCEMENTS
    // Admins write the announcement itself.
    // Any signed-in user can reply (replies subcollection).
    match /announcements/{annId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";

      // 💬 REPLIES — open to every signed-in user
      match /replies/{replyId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null &&
          (
            request.auth.uid == resource.data.authorId ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
          );
      }
    }

  }
}
