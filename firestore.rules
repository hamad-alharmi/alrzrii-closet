rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAuth() {
      return request.auth != null;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    // Files — admins write, anyone reads
    match /files/{fileId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Comments — any authenticated user can create
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() &&
          (resource.data.authorId == request.auth.uid || isAdmin());

        // Replies — any authenticated user can create
        match /replies/{replyId} {
          allow read: if true;
          allow create: if isAuth();
          allow update, delete: if isAuth() &&
            (resource.data.authorId == request.auth.uid || isAdmin());
        }
      }

      // Likes — user can only write their own like doc
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth() && request.auth.uid == userId;
      }
    }

    // Categories — admin writes, anyone reads
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Announcements — admin creates/updates/deletes the announcement itself
    // BUT any authenticated user can read AND create replies
    match /announcements/{annId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Replies — open to ALL authenticated users (any role)
      match /replies/{replyId} {
        allow read: if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() &&
          (resource.data.authorId == request.auth.uid || isAdmin());
      }
    }
  }
}
