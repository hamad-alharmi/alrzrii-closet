rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Users: only admins can write, authenticated users can read
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid);
      allow update: if isAdmin() || isOwner(uid);
      allow delete: if isAdmin();
    }

    // Files: only admins can write
    match /files/{fileId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Likes: authenticated users can manage their own
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Comments: authenticated users can write their own
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorUID == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUID == request.auth.uid);
    }

    // Replies: authenticated users can write their own
    match /replies/{replyId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorUID == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUID == request.auth.uid);
    }

    // Messages (announcements): only admins can post
    match /messages/{msgId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin();
    }

    // Message replies: authenticated users
    match /messageReplies/{replyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorUID == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.authorUID == request.auth.uid);
    }

    // Categories: admins manage, everyone reads
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site config: admins manage, everyone reads
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
